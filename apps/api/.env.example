# Server Configuration
HOST=0.0.0.0
PORT=8000
ENV=development

# ============================================================================
# API Keys (REQUIRED)
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here
SARVAM_API_KEY=your_sarvam_api_key_here

# ============================================================================
# LLM Configuration (Groq)
# Models: mixtral-8x7b-32768, llama-2-70b-chat-4096, gemma-7b-it
# ============================================================================
LLM_MODEL=mixtral-8x7b-32768
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TOP_P=1.0

# ============================================================================
# TTS Configuration (Sarvam AI)
# Sarvam streaming endpoint: https://api.sarvam.ai/text-to-speech/stream
# Bulbul v3 speakers include ratan and other dashboard voices.
# Languages use BCP-47 codes: hi-IN, en-IN, ta-IN, etc.
# ============================================================================
TTS_SPEAKER=ratan
TTS_LANGUAGE=hi-IN
TTS_MODEL=bulbul:v3
TTS_PITCH=1.0
TTS_PACE=1.1
TTS_SAMPLE_RATE=22050
TTS_AUDIO_CODEC=mp3

# ============================================================================
# Application Configuration
# ============================================================================
API_PREFIX=/api
LOG_LEVEL=INFO
