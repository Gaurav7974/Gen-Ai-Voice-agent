# ----------------------------------------------------------------------------
# GENA VOICE AI — Master Gitignore
# ----------------------------------------------------------------------------

# --- System / OS ---
.DS_Store
Thumbs.db
*.tmp
*.temp

# --- IDEs / Editors ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Node.js / Frontend (apps/web) ---
node_modules/
dist/
build/
.next/
.svelte-kit/
.turbo/
.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python (apps/api, scripts) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.noseids/
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.playwright-mcp/

# --- Environment & Secrets (NEVER COMMIT) ---
.env
.env.*
!.env.example
*.pem
*.key
certs/

# --- Databases & Vector Stores ---
*.db
*.sqlite3
chroma_store/
data/
storage/

# --- Tooling ---
.sisyphus/

# --- Media (Generated) ---
*.mp3
*.wav
*.m4a
output.*
screenshots/
